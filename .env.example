# ============================================================
# SOVEREIGN-Ω Environment Configuration
# Copy to .env for local dev. NEVER commit .env to git.
# For Render: set these in Dashboard → Environment tab.
# ============================================================

# ── REQUIRED: Pharos Chain ────────────────────────────────────────────────────
# Your agent/deployer wallet private key
# Local: set in .env  |  Render: set in dashboard (secret)  |  Replit: Replit Secrets
DEPLOYER_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

PHAROS_NETWORK=testnet
# Options: testnet (chain 688689) | mainnet (chain 1672)

# Deployed Pharos contract addresses
PHAROS_REGISTRY=0x6EAB7862385329BdaaD32f2b9587a66E768018Ba
PHAROS_VAULT=0xAbC106D943a6Aff91A0B29f4a77E4009323d7A66
PHAROS_LEARNER=0x799006C9b1e946d3A2909b81F3C3087D71bB9F84

# Agent operator wallet address
AGENT_OPERATOR_ADDRESS=0xdBbf66CAD621dA3Ec186D18b29a135d2A5d42d20

# ── REQUIRED: Trading ─────────────────────────────────────────────────────────
TRADING_ENABLED=true

# ── OPTIONAL: AI Reasoning ────────────────────────────────────────────────────
# Without this, agent runs in mock mode (Ψ max ~0.82, trade gate cannot open)
# With this, full Claude reasoning chains activate the Inferential + Perceptual planes
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── OPTIONAL: Database (PostgreSQL) ───────────────────────────────────────────
# Render add-on: postgres://user:pass@host:5432/dbname
# Leave blank to use file-based FAISS memory instead
DATABASE_URL=

# ── OPTIONAL: Social Bots ─────────────────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

TELEGRAM_BOT_TOKEN=

# ── Server ────────────────────────────────────────────────────────────────────
# Render injects PORT automatically — leave blank for Render deployments
PORT=5000
SESSION_SECRET=change_me_in_production
