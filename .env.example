# ============================================================
# SOVEREIGN-Ω Environment Configuration
# COPY THIS FILE TO .env AND FILL IN THE VALUES
# NEVER commit .env to git. It is already in .gitignore.
# ============================================================

# ----- REQUIRED: Pharos Chain -----
# Your deployer/agent private key (load from Replit secrets, not this file)
# DEPLOYER_PRIVATE_KEY=  ← Set in Replit Secrets, NOT here
PHAROS_NETWORK=testnet    # testnet | mainnet

# Deployed contract addresses (filled in after running deploy_pharos.sh)
PHAROS_REGISTRY=
PHAROS_VAULT=
PHAROS_LEARNER=

# Agent operator address (can be same as deployer)
AGENT_OPERATOR_ADDRESS=

# ----- OPTIONAL: Database -----
DATABASE_URL=postgresql://user:password@localhost:5432/sovereign_omega

# ----- OPTIONAL: AI / Reasoning -----
ANTHROPIC_API_KEY=

# ----- OPTIONAL: Social bots -----
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

TELEGRAM_BOT_TOKEN=

# ----- FastAPI -----
PORT=8000
SESSION_SECRET=   # Set in Replit Secrets

# ----- Trading -----
TRADING_ENABLED=false    # Start disabled. Enable after testing.
