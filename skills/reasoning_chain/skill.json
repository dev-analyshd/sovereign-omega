  "version": "2.0.0",
  "author": "SOVEREIGN-Ω",
  "chain": "Pharos",
  "chain_id_testnet": 688689,
  "tier": "premium",
  "x402_required": true,
  "x402_price": {
    "PROS": "2.0",
    "USDC": "0.20",
    "PROS_discounted": "1.6",
    "discount_note": "20% discount when paying in native $PROS"
  },
  "x402_facilitator": "https://facilitator.pharos.xyz",
  "x402_recipient": "0xdBbf66CAD621dA3Ec186D18b29a135d2A5d42d20",
  "x402_usdc_address": "0xE0BE08c77f415F577A1B3A9aD7a1Df1479564ec8",
  "x402_payment_flow": "/api/v1/x402/config → send on Pharos → /api/v1/x402/verify → invoke",
  "endpoint": "/api/v1/skills/invoke/reasoning_chain",
  "mcp_tool_name": "sovereign_reasoning_chain",
  "input_schema": {
    "type": "object",
    "required": ["query"],
    "properties": {
      "query": {
        "type": "string",
        "description": "The question or task to reason about"
      },
      "domain": {
        "type": "string",
        "enum": ["trading", "defi", "general"],
        "default": "general"
      },
      "context": {
        "type": "object",
        "description": "Optional context dict for the reasoning chains"
      },
      "max_chains": {
        "type": "integer",
        "minimum": 1,
        "maximum": 5,
        "default": 5,
        "description": "Number of parallel reasoning chains to run"
      }
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "answer": {"type": "string", "description": "Best answer from consensus"},
      "consensus_level": {"type": "number", "minimum": 0, "maximum": 1},
      "confidence": {"type": "number", "minimum": 0, "maximum": 1},
      "n_chains": {"type": "integer"},
      "contradiction_detected": {"type": "boolean"},
      "chain_summaries": {"type": "array", "items": {"type": "string"}},
      "psi_score": {"type": "number"}
    }
  },
  "tags": ["reasoning", "llm", "consensus", "premium", "x402", "pharos"]
